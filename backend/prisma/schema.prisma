// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  full_name     String?
  email         String   @unique
  password      String
  photo_profile String?
  bio           String?
  createAt      DateTime @default(now())

  replies   Replies[]
  likes     like[]
  following follow[]  @relation("following")
  follower  follow[]
  threads   threads[]
}

model follow {
  id           Int  @id @default(autoincrement())
  following_Id Int
  following    User @relation("following", fields: [following_Id], references: [id])

  follower_id Int
  follower    User @relation(fields: [follower_id], references: [id])
}

model like {
  id        Int      @id @default(autoincrement())
  user_id   Int
  userId    User     @relation(fields: [user_id], references: [id])
  thread_id Int
  threadin  threads  @relation(fields: [thread_id], references: [id])
  createAt  DateTime @default(now())
  updateAt  DateTime @default(now())
}

model Replies {
  id Int @id @default(autoincrement())

  user_id Int
  Users   User @relation(fields: [user_id], references: [id])

  thread_Id Int
  thread    threads @relation(fields: [thread_Id], references: [id])

  image    String?
  content  String
  createAt DateTime @default(now())
  updateAt DateTime @default(now())
}

model threads {
  id                Int      @id @default(autoincrement())
  content           String?
  image             String?
  number_of_replies Int      @default(0)
  created_at        DateTime @default(now())

  created_by Int
  author     User @relation(fields: [created_by], references: [id], onDelete: Cascade)

  updateAt DateTime @default(now())

  thread Replies[]
  likes  like[]
}
